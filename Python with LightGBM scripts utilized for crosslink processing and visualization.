# Define the Labeling Function and Apply It
# -----------------------------------------------
def label_csm_row(row):
    if row['MS'] == 'noncleaved':
        return np.nan
    c = row['PPI.Score']
    if c < 10:
        return 0
    elif c >= 284:
        return 1
    else:
        return np.nan

df['label'] = df.apply(label_csm_row, axis=1)

logger.info("Labeling function applied.")

