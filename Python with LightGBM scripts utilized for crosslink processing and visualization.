logger.info("Logging has been set up successfully.")

# -----------------------------------------------
# Define the sanitize_filename Function
# -----------------------------------------------
def sanitize_filename(name):
    """
    Sanitize the feature name to create a safe filename by replacing
    non-alphanumeric characters with underscores.

    Parameters:
    - name (str): The original feature name.

    Returns:
    - str: The sanitized feature name.
    """
    # Replace any character that is not alphanumeric or underscore with an underscore
    return re.sub(r'[^A-Za-z0-9_]+', '_', name)

