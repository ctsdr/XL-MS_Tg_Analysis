# -----------------------------------------------
# 10. Hyperparameter Tuning with Optuna
# -----------------------------------------------
logger.info("Starting hyperparameter tuning with Optuna.")

def objective(trial):
    # Define the hyperparameter search space
    param = {
        'objective': 'binary',
        'metric': 'auc',
        'boosting_type': 'gbdt',
        'is_unbalance': True,
        'random_state': 42,
        'num_leaves': trial.suggest_int('num_leaves', 15, 127),
        'learning_rate': trial.suggest_float('learning_rate', 0.005, 0.3, log=True),
        'max_depth': trial.suggest_int('max_depth', 5, 50),
        'min_child_samples': trial.suggest_int('min_child_samples', 5, 100),
        'subsample': trial.suggest_float('subsample', 0.5, 1.0),
        'colsample_bytree': trial.suggest_float('colsample_bytree', 0.5, 1.0),
        'reg_alpha': trial.suggest_float('reg_alpha', 0.0, 10.0),
        'reg_lambda': trial.suggest_float('reg_lambda', 0.0, 10.0),
    }


# -----------------------------------------------
# 11. Set Up Cross-Validation with Callbacks
# -----------------------------------------------
    n_splits = 3
    skf = StratifiedKFold(n_splits=n_splits, shuffle=True, random_state=49)

    logger.info(f"Starting {n_splits}-Fold Stratified Cross-Validation.")

# Define callbacks for cross-validation
# you need this for Early Stopping.
    callbacks_cv = [
    lgb.log_evaluation(period=10),  # Logs every 10 rounds
    lgb.early_stopping(stopping_rounds=100, verbose=True)
    ]

# Perform cross-validation with callbacks
    cv_results = lgb.cv(
      param, #changed to param from the params !!!
      lgb_dataset,
      num_boost_round=1000,
      folds=skf.split(X_train, y_train),
      seed=49,
      stratified=True, #do we need this?
      callbacks=callbacks_cv
    )

    # Extract the best score
    best_score = max(cv_results['valid auc-mean']) #auc-mean is valid auc-mean
    return best_score

# Create a study object and optimize the objective function
study = optuna.create_study(direction='maximize', study_name='lightgbm_hyperparameter_tuning')
study.optimize(objective, n_trials=100)

# Log the best hyperparameters
logger.info(f"Best hyperparameters found by Optuna: {study.best_params}")
logger.info(f"Best AUC from Optuna: {study.best_value:.4f}")

# Update the parameters with the best hyperparameters
params.update(study.best_params)

# Since 'metric' might be overwritten, ensure it's included
params['metric'] = ['auc', 'binary_logloss']


