## 9. Construct feature tables for machine learning

Run this section when rebuilding `ToxoDB67_AllFeature_woSTRING.txt` and `ToxoDB67_AllSTRING.txt` from source annotation files. Skip this section if those feature tables already exist and you only need to process XL-MS data.

```{r build-feature-tables}
# Load ToxoDB feature annotations. Column names are normalized so they can be used safely in dplyr.
featureDF <- read_excel("ToxoDB67_GO_TGME49.xlsx") %>%
  rename_with(~ gsub(" ", "_", .x))%>% #excel has space in the column name. replace with "_"
  rename_with(~ gsub("/", "_", .x)) #also remove "/" from the column name
# Helper: concatenate unique non-missing values within each grouped gene.
concat_unique <- function(x) {
  unique_x <- unique(x)
  str_c(unique_x[!is.na(unique_x)], collapse = ";")
}

featureDF <- featureDF %>%
  group_by(Gene_ID) %>%
  summarise(across(everything(), ~concat_unique(.x), .names = "{.col}_c"), .groups = 'drop')

# Helper: remove redundant semicolon-delimited values from each cell.
clean_values <- function(x) {
  # Ensure the input is treated as character text before splitting.
  x <- as.character(x)
  # Split on semicolons, remove uninformative values, deduplicate, and collapse back to one string.
  str_split(x, pattern = ";") %>% 
    map(~.x[.x != "N/A"]) %>%  # Remove "N/A" values
    map(~.x[.x != "GO:0016020"]) %>%  # Remove the specific element "GO:0016020"
    map(unique) %>%  # Remove duplicate values
    map_chr(~str_c(.x, collapse = ";"))
}

# Clean all feature columns after gene-level summarization.
featureDF <- featureDF %>%
  mutate(across(everything(), clean_values))

# Add CRISPR phenotype scores to the feature table.
CRISPRdf <- read_excel("ToxoDB67_CRISPR.xlsx")%>%
