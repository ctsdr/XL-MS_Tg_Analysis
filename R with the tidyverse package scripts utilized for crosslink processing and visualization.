  mutate(NonSyn_Syn_SNP_Ratio_All_Strains_c.x = as.numeric(NonSyn_Syn_SNP_Ratio_All_Strains_c.x),
         NonSyn_Syn_SNP_Ratio_All_Strains_c.y = as.numeric(NonSyn_Syn_SNP_Ratio_All_Strains_c.y),
        NonSyn_Syn_SNP_Ratio_All_Strains.dif = Q(NonSyn_Syn_SNP_Ratio_All_Strains_c.x, NonSyn_Syn_SNP_Ratio_All_Strains_c.y))

# Use the lower RNA-seq abundance of the two partners as a conservative expression feature.
df <- df %>%
  rowwise() %>%
  mutate(RnaSeq.min = min(c(RnaSeq.x, RnaSeq.y), na.rm = TRUE)) %>%
  ungroup()

# Keep only model-ready features and core PPI identifiers.
df <- df %>% select(
  PPI,
  Accession.A,
  Accession.B,
  Confidence.Q,
  MS,
  number_unique_RR,
  Number.of.CSMs,
  number_unique_intra.min,
  #number_unique_intra.hm,
  Computed_GO_Component_IDs_c_matches,
  Computed_GO_Function_IDs_c_matches,
  Computed_GO_Process_IDs_c_matches,
  EC_numbers_from_OrthoMCL_c_matches,
  PFam_ID_c_matches,
  ToxoNET_matches,
  Location_matches,
  CRISPR.dif,
  NonSyn_Syn_SNP_Ratio_All_Strains.dif,
  RnaSeq.min,
  STRING.score,
  PPI.Score
)

# Export the ML-ready feature matrix.
write.table(df, file = "PPI_full_wFeatures.txt", sep = "\t", row.names = FALSE, col.names = TRUE, quote = FALSE)
