## 21. Curated toxofilin-actin RRI export

Actins have many isoforms, so this targeted export focuses on ACTB (`P63261`), which has the most hits in this dataset.
```{r}
toxofilin.df <- read.table("20240908_All_for_publication-TxHu_Crosslinks.txt", header = TRUE, sep = "\t") %>%
  filter(Decoy != "True",
         Crosslink.Type == "Inter",
         str_detect(Accession.A, "TGME49_214080")|str_detect(Accession.B, "TGME49_214080")) %>%
  # Split multi-protein accessions into separate observations before filtering to ACTB.
  separate_rows(Accession.A, In.protein.A, sep = ";") %>% # Split multiple candidate proteins for peptide A into separate rows.
  mutate(Accession.A = str_trim(Accession.A)) %>% # Remove leading/trailing whitespace introduced by semicolon splitting.
  separate_rows(Accession.B, In.protein.B, sep = ";") %>% #split multiple observations in peptide B
  mutate(Accession.B = str_trim(Accession.B)) %>% # Remove leading/trailing whitespace introduced by semicolon splitting.
  filter(str_detect(Accession.A, "P63261") | str_detect(Accession.B, "P63261")) %>% # Keep only toxofilin links involving ACTB.
  # Collapse peptide-level toxofilin/ACTB observations to unique RRIs.
  rowwise() %>%
  mutate(
    RRI = {
      # Build the two `protein:position` strings on the fly.
      R1 <- str_c(Accession.A, In.protein.A, sep = ":")
      R2 <- str_c(Accession.B, In.protein.B, sep = ":")
      # Sort the two residue identifiers so reciprocal observations collapse together.
      paste(sort(c(R1, R2)), collapse = "-")
    }
  ) %>%
  ungroup() %>%
  # Aggregate all peptide-level entries that share the same RRI.
  group_by(RRI) %>%
  mutate(Number.of.CSMs = sum(Number.of.CSMs)) %>%
  slice_max(order_by = Best.CSM.Score, n = 1, with_ties = FALSE) %>%
  ungroup()

# Write the curated toxofilin-actin RRI table.
write.table(toxofilin.df,
  file = "toxofilin-actin-RRI.tsv",    # this is detailed RRI for dimers
  sep = "\t", quote = FALSE, row.names = FALSE, col.names = TRUE)
```


## 22. Export xiView table for the GRA network

This section converts the RRI table to xiView-compatible columns for a Cytoscape-derived GRA subnetwork.

```{r xiview-gra-export}
# Read the Cytoscape-derived list of GRA-network nodes.
gra.list <- read.csv(file = "GRA network default node.csv")
# Read merged RRI data and retain links where both proteins are in the GRA node list.
xiview.df <- read.csv("RRI.full.csv", header = TRUE, sep = "\t", quote = "") %>%
  filter(Confidence.Q >= 2) %>% # Retain Confidence.Q >= 2 for this focused xiView export; adjust if a stricter set is needed.
  # Keep rows where both linked proteins occur in the selected GRA network.
  filter(Accession.A %in% gra.list$name &
         Accession.B %in% gra.list$name) %>%
# Convert RRI rows to xiView column conventions.
  # xiView expects raw peptide sequences without bracketed linked residues.
  mutate(across(c(Sequence.A, Sequence.B), ~ stringr::str_remove_all(., "\\[|\\]"))) %>%
  # Calculate peptide start positions from protein residue positions and within-peptide link sites.
    mutate(
    PepPos1 = as.numeric(In.protein.A) - as.numeric(Position.A) + 1,
    PepPos2 = as.numeric(In.protein.B) - as.numeric(Position.B) + 1
  ) %>%
  # Rename fields to xiView-compatible column names.
  rename(PepSeq1 = Sequence.A,
         PepSeq2 = Sequence.B,
         LinkPos1 = Position.A,
         LinkPos2 = Position.B,
         Protein1 = Accession.A,
         Protein2 = Accession.B,
         Score = Confidence.Q)

# Save the xiView-ready GRA-network table.
write.csv(xiview.df, "xiVIEW_GRA_exclusive.csv", row.names = FALSE, quote = FALSE)
```


