        TRUE_count  = ~ sum(. == TRUE,  na.rm = TRUE),
        FALSE_count = ~ sum(. == FALSE, na.rm = TRUE),
        NA_count    = ~ sum(is.na(.))
      ),
      .names = "{.col}_{.fn}"
    ),
    .groups = "drop"
  )
# Calculate percentage agreement after excluding missing feature evidence.
ag.percent <-  ag.df %>%
  group_by(Confidence.Q) %>%
  summarise(
    across(
      ends_with("_matches"),
      ~ {
        n_true  <- sum(. == TRUE,  na.rm = TRUE)
        n_false <- sum(. == FALSE, na.rm = TRUE)
        100 * n_true / (n_true + n_false)
      },
      .names = "{.col}_pct_true"
    ),
    .groups = "drop"
  ) %>%
  arrange(desc(Confidence.Q))
```




## 20. Detect putative dimers from overlapping intraprotein peptide pairs

Prerequisite: `RRI_full` must contain all merged residue-residue interactions.

The logic below identifies intraprotein RRIs where the two linked peptide spans overlap. Such links can indicate a dimer or oligomer because the same protein sequence region cannot crosslink to itself within a single linear molecule.

```{r dimer-detection}
# Reload the merged RRI table if the current session does not already contain RRI_full.
RRI_full <- read.table("RRI.full.csv", header = TRUE, sep = "\t", quote   = "")

dimer_df <- RRI_full %>%
  filter(Confidence.Q >= 3)%>% # Retain confidence Q >= 3. Update this threshold if a stricter dimer set is needed.
  filter(Accession.A == Accession.B) %>%
    # Some peptide mappings contain multiple positions; use the first position for peptide-span checks.
  mutate(
    # Extract the first semicolon-delimited residue position and convert it to numeric.
    In.protein.A = as.numeric(str_split(In.protein.A, ";", simplify = TRUE)[,1]),
    In.protein.B = as.numeric(str_split(In.protein.B, ";", simplify = TRUE)[,1]),

    # Calculate peptide start positions from linked residue position and within-peptide link position.
    Peptide.A.Start = In.protein.A - Position.A + 1,
    Peptide.B.Start = In.protein.B - Position.B + 1,
    
    # Extract substring after ']' in Sequence.A and Sequence.B
    # Calculate peptide end positions from the sequence after the linked residue marker.
    Peptide.A.End = In.protein.A + str_length(str_remove(Sequence.A, "^.*\\]")),
    Peptide.B.End = In.protein.B + str_length(str_remove(Sequence.B, "^.*\\]")),
    
    # Flag cases where the two peptide spans overlap.
    Dimer = (Peptide.A.Start <= Peptide.B.End) & (Peptide.B.Start <= Peptide.A.End)
  ) %>%
    filter(Dimer == TRUE)

# Summarize candidate dimers by gene and build XlinkCyNET-style crosslink strings.
dimer_detect <- dimer_df %>%
  group_by(Accession.A) %>%
  summarise(dimer_RRI = n(),
            crosslinks_ab = paste(Accession.A, In.protein.A, Accession.B, In.protein.B, sep = "-", collapse = "#"),
            score_ab = paste(Confidence.Q, collapse = "#")
            ) %>%
  ungroup() 

gene.name <- read.table(file = "GeneNameLookupTableTxHu.csv", sep = "\t", header = TRUE, quote = "") %>%
    distinct(gene, .keep_all = TRUE)

# Add gene-product descriptions and duplicate fields required by XlinkCyNET self-edge formatting.
dimer_detect <- dimer_detect %>%
  left_join(gene.name, by = c("Accession.A" = "gene")) %>%
  #XlinkCyNET format
  mutate(
  gene_a = Accession.A,
  gene_b = Accession.A,
  ppi_score = as.numeric(score_ab) * as.numeric(dimer_RRI),
  crosslinks_ba = crosslinks_ab,
  score_ba = score_ab,
  protein_a = gene_a,
  protein_b = gene_b
)

# Add gene-product descriptions to the detailed dimer RRI table.
dimer_df <- dimer_df %>%
  left_join(gene.name, by = c("Accession.A" = "gene"))

# Export the dimer summary table.
write.table(dimer_detect,
  file = "dimer_detect.tsv",    # summary of dimers
  sep = "\t", quote = FALSE, row.names = FALSE, col.names = TRUE)

# Export detailed RRI-level evidence for candidate dimers.
write.table(dimer_df,
  file = "dimer_df.tsv",    # this is detailed RRI for dimers
  sep = "\t", quote = FALSE, row.names = FALSE, col.names = TRUE)
```

