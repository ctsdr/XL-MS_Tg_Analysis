## 17. Build the PPI feature matrix for ML prediction

This section joins gene-level features to both proteins in each PPI, adds interaction-level STRING evidence, and engineers pairwise features for prediction. The resulting `PPI_full_wFeatures.txt` table is the input for the external LightGBM/neural-network prediction workflow.

```{r build-ppi-feature-matrix}
# Read precomputed gene-level and STRING interaction-level feature tables.
featureDF <- read.table(file = "ToxoDB67_AllFeature_woSTRING.txt", sep = "\t", header = TRUE)
STRINGdf <- read.table(file = "ToxoDB67_AllSTRING.txt", sep = "\t", header = TRUE)

# Standardize the STRING score column name.
# `ToxoDB67_AllSTRING.txt` generated above already uses STRING.score; raw STRING exports may use combined_score.
if ("combined_score" %in% names(STRINGdf) && !"STRING.score" %in% names(STRINGdf)) {
  STRINGdf <- STRINGdf %>% rename(STRING.score = combined_score)
}

# Append gene-level features to both PPI partners and append STRING evidence by PPI key.
df <- PPI_full %>%
  left_join(featureDF, by = c("Accession.A" = "Gene_ID"))%>%
  left_join(featureDF, by = c("Accession.B" = "Gene_ID"))%>%
  left_join(STRINGdf, by = "PPI")
# Helper: check whether two semicolon-delimited feature strings share at least one value.
# Used for GO terms, PFam domains, ToxoNET clusters, and localization annotations.

find_matches_boolean <- function(x, y) {
  # Convert inputs to character to avoid type issues during string splitting.
  x <- as.character(x)
  y <- as.character(y)
  
  # Treat missing values and paired "0" placeholders as unavailable evidence.
  na_or_zero_check <- is.na(x) || is.na(y) || (x == "0" && y == "0")
  
  # Split the strings into vectors based on the ";" delimiter, if not NA or "0"
  if (!na_or_zero_check) {
    items_x <- unlist(strsplit(x, split = ";", fixed = TRUE))
    items_y <- unlist(strsplit(y, split = ";", fixed = TRUE))
    
    # Return TRUE when the two feature sets overlap.
    return(length(intersect(items_x, items_y)) > 0)
  } else {
    # Return NA when feature evidence is unavailable.
    return(NA)
  }
}

# Identify `.x` / `.y` feature column pairs corresponding to proteins A and B,
# then calculate a new `<feature>_matches` column for each pair.
# Extract all column names in the merged feature table.
col_names <- names(df)

# Identify candidate feature prefixes by stripping `.x` and `.y` suffixes.
prefixes <- unique(sub("\\.(x|y)$", "", col_names))

# Keep only feature prefixes that have both protein-A and protein-B columns.
valid_prefixes <- prefixes[sapply(prefixes, function(prefix) {
  all(c(paste0(prefix, ".x"), paste0(prefix, ".y")) %in% col_names)
})]

# Compare each feature pair row-by-row and write a boolean match column.
for (prefix in valid_prefixes) {
  x_col <- paste0(prefix, ".x")
  y_col <- paste0(prefix, ".y")
  match_col <- paste0(prefix, "_matches") # New column for match results
  
  # Apply the matching function to each row for the current pair of columns
  df[[match_col]] <- mapply(find_matches_boolean, df[[x_col]], df[[y_col]], SIMPLIFY = TRUE)
}


# Helper: calculate absolute numeric differences, doubling the difference when signs differ.
# This gives extra weight to protein pairs with opposite phenotype/evolutionary effects.
Q <- function(x, y) {
  D <- abs(x - y)
  delta <- ifelse(sign(x) != sign(y), 1, 0)
  Q_value <- D * (1 + delta)
  return(Q_value)
}

# Engineer CRISPR-score difference between the two PPI partners.
df <- df %>%
  mutate(CRISPR.x = as.numeric(CRISPR.x),
         CRISPR.y = as.numeric(CRISPR.y),
         CRISPR.dif = Q(CRISPR.x, CRISPR.y))
# Engineer nonsynonymous/synonymous SNP-ratio difference between the two PPI partners.
