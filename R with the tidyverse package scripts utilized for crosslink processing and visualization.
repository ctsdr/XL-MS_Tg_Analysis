  summary_df$Metric == "Total Observations RRI cleaved" ~ "Total Observations (Cleaved)",
  summary_df$Metric == "Unique RRIs RRI noncleaved" ~ "Unique RRIs (noncleaved)",
  summary_df$Metric == "Unique RRIs RRI cleaved" ~ "Unique RRIs (Cleaved)",
  summary_df$Metric == "Shared RRIs" ~ "Shared RRIs",
  summary_df$Metric == "Shared RRIs Intra" ~ "Shared RRIs (Intra)",
  summary_df$Metric == "Shared RRIs Inter" ~ "Shared RRIs (Inter)",
  summary_df$Metric == "Unique RRIs only RRI noncleaved" ~ "Unique RRIs Only (noncleaved)",
  summary_df$Metric == "Unique RRIs only RRI cleaved" ~ "Unique RRIs Only (Cleaved)",
  TRUE ~ summary_df$Metric
)

