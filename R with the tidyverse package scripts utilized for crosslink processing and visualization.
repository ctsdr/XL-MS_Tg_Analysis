  "Total_Observations_RRI_noncleaved",
  "Total_Observations_RRI_cleaved",
  "Unique_RRIs_RRI_noncleaved",
  "Unique_RRIs_RRI_cleaved",
  "Shared_RRIs",
  "Shared_RRIs_Intra",
  "Shared_RRIs_Inter",
  "Unique_RRIs_only_RRI_noncleaved",
  "Unique_RRIs_only_RRI_cleaved"
)

summary_df <- summary_df %>%
