```{r}
#load feature data frame (see later section for how it was made)
RnaSeqDF <- read.table(file = "ToxoDB67_AllFeature_woSTRING.txt", sep = "\t", header = TRUE) %>%
  select(Gene_ID, RnaSeq)

rawdf2 <- rawdf %>%
  #label the ambiguous hits. A for peptide A, B for peptide B, False for non-ambiguous
  mutate(
    Ambiguous = case_when(
      str_detect(Accession.A, ";") ~ "A",  # Label A if Accession.A contains ";"
      str_detect(Accession.B, ";") ~ "B",  # Label B if Accession.B contains ";"
      TRUE ~ "False"  # All other cases
    )) %>%
  separate_rows(Accession.A, In.protein.A, sep = ";") %>% #split multiple observations in peptide A
  mutate(Accession.A = str_trim(Accession.A)) %>% #remove the white space
  left_join(RnaSeqDF, by = c("Accession.A" = "Gene_ID")) %>%
  group_by(Crosslinks.Peptide.Group.ID) %>% #Group by the original identifier
  arrange(desc(RnaSeq), In.protein.A) %>%  # Sort by RnaSeq first and then In.protein.A as a tiebreaker
  slice_head(n = 1) %>% # Keep only the first row per group after sorting
  select(-RnaSeq) %>% #remove the RnaSeq column
  ungroup() %>%
  #perform the same with peptide B
  separate_rows(Accession.B, In.protein.B, sep = ";") %>% #split multiple observations in peptide B
  mutate(Accession.B = str_trim(Accession.B)) %>% #remove the white space
  left_join(RnaSeqDF, by = c("Accession.B" = "Gene_ID")) %>%
  group_by(Crosslinks.Peptide.Group.ID) %>% #Group by the original identifier
  arrange(desc(RnaSeq), In.protein.B) %>%  # Sort by RnaSeq first and then In.protein.A as a tiebreaker
  slice_head(n = 1) %>%  # Keep only the first row per group after sorting
  select(-RnaSeq) %>% #remove the RnaSeq column
  ungroup()
