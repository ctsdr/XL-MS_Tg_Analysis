                  na = c("", "NA"),
                  skip = 2) %>%
#removes suffix on protein names
  mutate(across(where(is.character), ~str_replace_all(., "-t26_1-p1", "")))%>%
  mutate(Protein = str_remove_all(Protein, "\\.P\\d{2,4}"))%>%
#convert probablity score to -log10
  mutate(Score = -log10(Score))%>%
#from the summary rows, add the Peptide_Order to the individual observations below
# Fill NA values in "Peptide_Order" with the previous non-NA value. This will be the key ID for two data frames
  mutate(Peptide_Order = str_replace_all(Peptide_Order, "[^0-9\\.]", "") %>% as.numeric())%>% #remove "SameSet" characters
  fill(Peptide_Order, .direction = "down")

#create summary data frame by "Protein" column is character
summarydf <- pLinkrawdf %>% filter(str_detect(Protein, "^[A-Z]"))%>%
                        select(-c(Precursor_Mass,Peptide,Peptide_Mass, Da, ppm, Alpha_Evalue, Beta_Evalue, Modifications, Peptide_Mass, Evalue, Score))
#Create observationdf: All other rows. keep entire observations with the highest Score per Peptide_Order
observationdf <- pLinkrawdf %>%
  filter(!str_detect(Protein, "^[A-Z]")) %>%                # Exclude rows where Protein starts with a capital letter
  group_by(Peptide_Order) %>%                               # Group by Peptide_Order
  slice_max(order_by = Score, n = 1, with_ties = FALSE) %>% # Keep the row with the highest Score per group
  ungroup() %>%
  select(c(Peptide_Order, Peptide, Score ))
#combine the best CSM score's observation to the summary
merged_summary <- summarydf %>% left_join(observationdf, by = "Peptide_Order") %>%
#split the Protein into Accession.A and B
  separate_rows(Protein, sep = "/")%>%
  filter(!is.na(Protein) & Protein != "")%>%
  separate(Protein, into = c("Accession.A", "Accession.B"), sep = "-", remove = FALSE)%>%
  # Separate Accession.A into Accession.A and In.protein.A
  separate(
    Accession.A,
    into = c("Accession.A", "In.protein.A"),
    sep = " ",                # Split at the first space
    extra = "merge",          # Merge any additional splits into the second column
    fill = "right"            # If there's no second part, fill with NA
  ) %>%
  # Clean In.protein.A by removing parentheses and any remaining whitespace
  mutate(
    In.protein.A = str_remove_all(In.protein.A, "[\\(\\)]")
  ) %>%
  # Repeat the separation for Accession.B
  separate(
    Accession.B,
    into = c("Accession.B", "In.protein.B"),
    sep = " ",                # Split at the first space
    extra = "merge",          # Merge any additional splits into the second column
    fill = "right"            # If there's no second part, fill with NA
  ) %>%
  # Clean In.protein.B by removing parentheses and any remaining whitespace
  mutate(
    In.protein.B = str_remove_all(In.protein.B, "[\\(\\)]")
  ) %>%
  # Check if they are Intra or Inter crosslinks
  mutate(Crosslink.Type = if_else(
    Accession.A == Accession.B,   # Condition
    "Intra",                       # Value if TRUE
    "Inter"                        # Value if FALSE
  )) %>%
  #Create PPI by %>%
  rowwise() %>%  # Apply operations row-wise
  mutate(
    # Combine accessions into a vector, sort them, and paste with "-"
    PPI = (paste(sort(c(Accession.A, Accession.B)), collapse = "-")
  )) %>%
  ungroup() %>%  # Remove row-wise grouping
  
  # remove the redundant PPI due to the non-unique peptide (one sequence hits multiple proteins)
  group_by(Peptide_Order) %>%                   # Group by Peptide_Order
  slice_min(order_by = PPI, n = 1, with_ties = FALSE) %>%  # Select the first aplhanumerical PPI per group
  ungroup() %>%
  
  #create peptide sequence "Sequence.A" position in peptide "Position.A" and B to be compatible with Annika 2.0
  separate(Peptide, into = c("Accession1", "Accession2"), sep = "-") %>%
  mutate(
    Sequence.A = str_extract(Accession1, "^[A-Za-z]+"),
    Position.A = as.integer(str_extract(Accession1, "[0-9]+")),
    Sequence.B = str_extract(Accession2, "^[A-Za-z]+"),
    Position.B = as.integer(str_extract(Accession2, "[0-9]+"))
    )%>%
   #convert pLink format of the peptide to Annika 2.0 format with the target residue in []
   mutate(
    Sequence.A = paste0(
      str_sub(Sequence.A, 1, Position.A - 1),
      "[", 
      str_sub(Sequence.A, Position.A, Position.A),
      "]",
      str_sub(Sequence.A, Position.A + 1)
    ),
      Sequence.B = paste0(
      str_sub(Sequence.B, 1, Position.B - 1),
      "[", 
      str_sub(Sequence.B, Position.B, Position.B),
      "]",
      str_sub(Sequence.B, Position.B + 1)
    )
  ) %>%
  # Create Residue to Residue Interaction (RRI)
  rowwise() %>%  # Apply operations row-wise
  mutate(
  RRA = paste(Accession.A, In.protein.A, sep = ":"),
  RRB = paste(Accession.B, In.protein.B, sep = ":")
  ) %>%
  ungroup() %>%
  rowwise() %>%
  mutate(RRI = paste(sort(c(RRA, RRB)), collapse = "-"))%>% #sort alphanumerical then combine to make RRI
  ungroup() %>% # Remove row-wise grouping
  select(-c(Accession1, Accession2, RRA, RRB)) #remove non-relevent columns
