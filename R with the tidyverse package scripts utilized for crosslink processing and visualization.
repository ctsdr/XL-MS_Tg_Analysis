## 6. Assign confidence labels and numeric confidence scores

This section removes decoys and assigns confidence labels based on the FDR-derived cutoffs calculated above. Intra-protein links keep Annika's original confidence label because the inter-link target-decoy thresholds are not applied to intralinks.

```{r assign-confidence}
#------------------RRI
# Remove decoy rows before producing clean RRI/PPI tables.
RRI_clean <- RRIdf %>% filter(Decoy == "False") %>%
# Assign confidence labels from score cutoffs for inter-protein links.
  arrange(desc(RRI.Score)) %>%
  mutate(Confidence_RRI = case_when(
    Crosslink.Type == "Intra" ~ Confidence, # Keep original values from the column Confidence for intralinks
    RRI.Score > cutoff_table_RRI %>% filter(FDR_target == 0.01) %>% pull(cutoff_score) ~ "High", # FDR <1%
    RRI.Score > cutoff_table_RRI %>% filter(FDR_target == 0.05) %>% pull(cutoff_score) ~ "Medium", # FDR <5%
    RRI.Score > cutoff_table_RRI %>% filter(FDR_target == 0.10) %>% pull(cutoff_score) ~ "Low", # FDR <10%
    RRI.Score > cutoff_table_RRI %>% filter(FDR_target == 0.30) %>% pull(cutoff_score) ~ "Purgatory", # FDR <30%
    RRI.Score <= cutoff_table_RRI %>% filter(FDR_target == 0.30) %>% pull(cutoff_score) ~ "Hell", # FDR >30%
    TRUE ~ Confidence # Default to keep original in all other cases
  ))

# Convert textual confidence labels into a numeric scale for filtering, summaries, and Cytoscape.
# Named vector mapping human-readable confidence labels to numeric Confidence.Q values.
confidence_map <- c("High" = 5, "Medium" = 4, "Low" = 3, "Purgatory" = 2, "Hell" = 1)
# Apply the mapping to create the Confidence.Q column.
RRI_clean <- RRI_clean %>%
  mutate(Confidence.Q = confidence_map[Confidence_RRI])

#------------------PPI
# Remove decoy rows before producing clean RRI/PPI tables.
PPI_clean <- PPIdf %>% filter(Decoy == "False") %>%
# Assign confidence labels from score cutoffs for inter-protein links.
  arrange(desc(PPI.Score)) %>%
  mutate(Confidence_PPI = case_when(
    Crosslink.Type == "Intra" ~ Confidence, # Keep original values from the column Confidence for intralinks
    PPI.Score > cutoff_table_PPI %>% filter(FDR_target == 0.01) %>% pull(cutoff_score) ~ "High", # FDR <1%
    PPI.Score > cutoff_table_PPI %>% filter(FDR_target == 0.05) %>% pull(cutoff_score) ~ "Medium", # FDR <5%
    PPI.Score > cutoff_table_PPI %>% filter(FDR_target == 0.10) %>% pull(cutoff_score) ~ "Low", # FDR <10%
    PPI.Score > cutoff_table_PPI %>% filter(FDR_target == 0.30) %>% pull(cutoff_score) ~ "Purgatory", # FDR <30%
    PPI.Score <= cutoff_table_PPI %>% filter(FDR_target == 0.30) %>% pull(cutoff_score) ~ "Hell", # FDR >30%
    TRUE ~ Confidence # Default to keep original in all other cases
  ))

# Convert textual confidence labels into a numeric scale for filtering, summaries, and Cytoscape.
# Named vector mapping human-readable confidence labels to numeric Confidence.Q values.
confidence_map <- c("High" = 5, "Medium" = 4, "Low" = 3, "Purgatory" = 2, "Hell" = 1)
# Apply the mapping to create the Confidence.Q column.
PPI_clean <- PPI_clean %>%
  mutate(Confidence.Q = confidence_map[Confidence_PPI])

```
