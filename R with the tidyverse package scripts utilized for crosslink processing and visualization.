#Define the Matching Function: We'll start with the matching function. It checks for any common elements between two semicolon-separated strings.

find_matches_boolean <- function(x, y) {
  # Convert inputs to character, in case they are not
  x <- as.character(x)
  y <- as.character(y)
  
  # Pre-calculate NA or "0" check
  na_or_zero_check <- is.na(x) || is.na(y) || (x == "0" && y == "0")
  
  # Split the strings into vectors based on the ";" delimiter, if not NA or "0"
  if (!na_or_zero_check) {
    items_x <- unlist(strsplit(x, split = ";", fixed = TRUE))
    items_y <- unlist(strsplit(y, split = ";", fixed = TRUE))
    
    # Return TRUE if there are any matches, taking into account the NA or "0" check
    return(length(intersect(items_x, items_y)) > 0)
  } else {
    # Return NA if either input is NA or both are "0"
    return(NA)
  }
}

#Identify and Process Column Pairs: We'll identify the pairs of columns that need to be compared and then iterate over these pairs, applying the matching function to each pair and storing the result in a new column.
# Extract column names
col_names <- names(df)

# Identify unique prefixes by removing the trailing .x and .y
prefixes <- unique(sub("\\.(x|y)$", "", col_names))

# Filter out prefixes to ensure both .x and .y versions exist
valid_prefixes <- prefixes[sapply(prefixes, function(prefix) {
  all(c(paste0(prefix, ".x"), paste0(prefix, ".y")) %in% col_names)
})]

# Iterate over each valid prefix and compare the .x and .y columns
for (prefix in valid_prefixes) {
  x_col <- paste0(prefix, ".x")
  y_col <- paste0(prefix, ".y")
  match_col <- paste0(prefix, "_matches") # New column for match results
  
  # Apply the matching function to each row for the current pair of columns
  df[[match_col]] <- mapply(find_matches_boolean, df[[x_col]], df[[y_col]], SIMPLIFY = TRUE)
}


# Define the function Q(x, y) for calculating absolute difference, 2x if they are + and -
Q <- function(x, y) {
  D <- abs(x - y)
  delta <- ifelse(sign(x) != sign(y), 1, 0)
  Q_value <- D * (1 + delta)
  return(Q_value)
}

