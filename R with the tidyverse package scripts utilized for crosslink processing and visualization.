## 15. Collapse non-cleavable pLink RRIs to PPIs

This section summarizes pLink-derived RRIs at the PPI level, counts supporting residue pairs and spectra, and appends intralink-support features for downstream neural-network / LightGBM-style feature construction.

```{r condense-plink-ppi}
# Before PPI condensation, calculate protein-level intralink support from the pLink RRI table.
# Count unique intralinks per protein at the pLink FDR10 level.
intracalc <- RRI_noncleaved_FDR10 %>%
    filter(Crosslink.Type == "Intra") %>%
    mutate(Accession.A = str_remove_all(Accession.A, "\\s*\\([^)]*\\)"))%>% # Remove parenthetical residue information from accessions before joining by protein ID.
  group_by(Accession.A) %>%
  mutate(number_unique_intra = n()) %>%
  ungroup()%>%  # Optionally, remove the grouping information
  group_by(Accession.A) %>%
    # Select the row with the highest 'Best.CSM.Score' for each 'PPI'
    filter(Score == max(Score)) %>%
    ungroup() %>%
    distinct(Accession.A, .keep_all = TRUE)%>% #remove redundancy
    select(Accession.A, number_unique_intra) #select ID and interlink number

# Helper: collapse a pLink RRI table into one row per PPI.
#
# Args:
#   data: pLink-derived RRI table, for example `RRI_noncleaved_FDR10`.
#   confidence_q: Confidence.Q value assigned to rows from that FDR threshold.
#
# Returns:
#   PPI-level table with CSM counts, number of unique RRIs, and XlinkCyNET-style
#   concatenated crosslink/score strings.
process_PPI <- function(data, confidence_q) {
  data %>%
    group_by(PPI) %>%
    mutate(
      number_unique_RR = n(), # Count supporting residue-residue interactions.
      Number.of.CSMs = sum(Number.of.CSMs, na.rm = TRUE), # Sum supporting spectra within each PPI.
      # Build XlinkCyNET-style concatenated residue-pair and score strings.
      crosslinks_ab = paste(Accession.A, In.protein.A, Accession.B, In.protein.B, sep = "-", collapse = "#"),
      score_ab = paste(Score, collapse = "#")
    ) %>%
    filter(Score == max(Score, na.rm = TRUE)) %>% # Keep the highest-scoring representative row per PPI.
    ungroup() %>%
    mutate(PPI.Score = Score) %>% # Store the representative pLink score as the PPI score.
    select(-c(
      Unique_Peptide_Number,
      Protein,
      In.protein.A,
      In.protein.B,
      Sequence.A,
      Sequence.B,
      Position.A,
      Position.B,
      Score
    )) %>%
    # Clean accessions and attach the requested confidence value.
    mutate(
      Accession.A = str_remove_all(Accession.A, "\\s*\\([^)]*\\)"), # Remove parenthetical residue annotations from Accession.A.
      Accession.B = str_remove_all(Accession.B, "\\s*\\([^)]*\\)"), # Remove parenthetical residue annotations from Accession.B.
      Confidence.Q = confidence_q # Assign the specified Confidence.Q value
    )
}

# Apply the helper to each pLink FDR threshold table.

# Process FDR10 with Confidence.Q = 3
PPI_condensed_FDR10 <- process_PPI(RRI_noncleaved_FDR10, 3)
# Process FDR05 with Confidence.Q = 4
PPI_condensed_FDR05 <- process_PPI(RRI_noncleaved_FDR05, 4)
# Process FDR01 with Confidence.Q = 5.
PPI_condensed_FDR01 <- process_PPI(RRI_noncleaved_FDR01, 5)

# Merge PPI lists from FDR10, FDR05, and FDR01. A PPI is upgraded to a higher
# Confidence.Q if it appears in a stricter threshold set.
PPI_noncleaved_full <- PPI_condensed_FDR10 %>%
  mutate(Confidence.Q = if_else(PPI %in% PPI_condensed_FDR05$PPI, 4, Confidence.Q)) %>%
  mutate(Confidence.Q = if_else(PPI %in% PPI_condensed_FDR01$PPI, 5, Confidence.Q)) %>%
  mutate(MS = "noncleaved") %>% # Label all rows as non-cleavable XL-MS evidence.
  filter(Crosslink.Type == "Inter") # Retain interprotein PPIs for interactome-level analyses.

# Append intralink-support features for each protein and keep conservative summaries.
PPI_noncleaved_full <- PPI_noncleaved_full %>%
  left_join(intracalc, by = "Accession.A") %>%
  left_join(intracalc, by = c("Accession.B" = "Accession.A"))%>%
  # Replace NA with 0 and compute the minimum of 'number_unique_intra.x' and 'number_unique_intra.y'
  mutate(number_unique_intra.min = pmin(replace_na(number_unique_intra.x, 0), replace_na(number_unique_intra.y, 0), na.rm = TRUE)) %>%
  mutate(number_unique_intra.hm = 2 * (number_unique_intra.x * number_unique_intra.y)/(number_unique_intra.x + number_unique_intra.y)) %>%
  # Remove the old columns 'number_unique_intra.x' and 'number_unique_intra.y'
  select(-number_unique_intra.x, -number_unique_intra.y)
