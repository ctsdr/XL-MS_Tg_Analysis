## 10. Process non-cleavable pLink search reports

Before running this section, perform pLink3 searches at PPI-level FDR thresholds of 10%, 5%, and 1%.

pLink report tables mix summary rows and observation rows. The code below uses `Peptide_Order` to link summary information with the best-scoring observation, then converts the result into the same style of RRI table used for Annika output.

```{r process-plink-report}
# Define pLink report column names because the CSV export has non-standard header rows.
column_names <- c("Peptide_Order", "Protein", "Unique_Peptide_Number", "Number.of.CSMs", "Precursor_Mass", "Peptide", "Peptide_Mass",                   "Modifications", "Evalue", "Score", "Da", "ppm", "Alpha_Evalue", "Beta_Evalue")
# Read one pLink report. Run this import block separately for the 10%, 5%, and 1% FDR files.
pLinkrawdf <- read.table(
  "pLink_cross-linked_sitesFDR10.csv", 
  #"pLink_cross-linked_sitesFDR05.csv", 
  #"pLink_cross-linked_sitesFDR01.csv", 
                  col.names = column_names, 
                  header = FALSE, 
                  sep = ",", 
                  fill = TRUE, 
                  stringsAsFactors = FALSE,
                  na = c("", "NA"),
                  skip = 2) %>%
# Normalize protein accessions to match the cleavable Annika workflow.
  mutate(across(where(is.character), ~str_replace_all(., "-t26_1-p1", "")))%>%
  mutate(Protein = str_remove_all(Protein, "\\.P\\d{2,4}"))%>%
# Convert pLink probability/E-value style scores to -log10 scores so larger values indicate stronger evidence.
  mutate(Score = -log10(Score))%>%
# Propagate Peptide_Order from summary rows to the observation rows below them.
# Fill missing Peptide_Order values downward; this becomes the key for joining summary and observation rows.
  mutate(Peptide_Order = str_replace_all(Peptide_Order, "[^0-9\\.]", "") %>% as.numeric())%>% #remove "SameSet" characters
  fill(Peptide_Order, .direction = "down")

# Summary rows contain the protein-pair assignment.
summarydf <- pLinkrawdf %>% filter(str_detect(Protein, "^[A-Z]"))%>%
                        select(-c(Precursor_Mass,Peptide,Peptide_Mass, Da, ppm, Alpha_Evalue, Beta_Evalue, Modifications, Peptide_Mass, Evalue, Score))
# Observation rows contain peptide/score details. Keep the highest-scoring observation per Peptide_Order.
observationdf <- pLinkrawdf %>%
  filter(!str_detect(Protein, "^[A-Z]")) %>%                # Exclude rows where Protein starts with a capital letter
  group_by(Peptide_Order) %>%                               # Group by Peptide_Order
  slice_max(order_by = Score, n = 1, with_ties = FALSE) %>% # Keep the row with the highest Score per group
  ungroup() %>%
  select(c(Peptide_Order, Peptide, Score ))
# Merge the best observation back into the summary rows and parse pLink protein/residue strings.
merged_summary <- summarydf %>% left_join(observationdf, by = "Peptide_Order") %>%
# Split pLink protein-pair strings into accession and residue-position fields.
  separate_rows(Protein, sep = "/")%>%
  filter(!is.na(Protein) & Protein != "")%>%
  separate(Protein, into = c("Accession.A", "Accession.B"), sep = "-", remove = FALSE)%>%
  # Separate Accession.A into Accession.A and In.protein.A
  separate(
    Accession.A,
    into = c("Accession.A", "In.protein.A"),
    sep = " ",                # Split at the first space
    extra = "merge",          # Merge any additional splits into the second column
    fill = "right"            # If there's no second part, fill with NA
  ) %>%
  # Clean In.protein.A by removing parentheses and any remaining whitespace
  mutate(
    In.protein.A = str_remove_all(In.protein.A, "[\\(\\)]")
  ) %>%
  # Repeat the separation for Accession.B
  separate(
    Accession.B,
    into = c("Accession.B", "In.protein.B"),
    sep = " ",                # Split at the first space
    extra = "merge",          # Merge any additional splits into the second column
    fill = "right"            # If there's no second part, fill with NA
  ) %>%
  # Clean In.protein.B by removing parentheses and any remaining whitespace
  mutate(
    In.protein.B = str_remove_all(In.protein.B, "[\\(\\)]")
  ) %>%
  # Classify intraprotein versus interprotein crosslinks.
  mutate(Crosslink.Type = if_else(
    Accession.A == Accession.B,   # Condition
    "Intra",                       # Value if TRUE
    "Inter"                        # Value if FALSE
  )) %>%
  # Create a direction-independent PPI key.
  rowwise() %>%  # Apply operations row-wise
  mutate(
    # Sort accessions so reciprocal protein pairs collapse to the same PPI.
    PPI = (paste(sort(c(Accession.A, Accession.B)), collapse = "-")
  )) %>%
  ungroup() %>%  # Remove row-wise grouping
  
  # When one peptide sequence maps to multiple proteins, keep one deterministic PPI per Peptide_Order.
  group_by(Peptide_Order) %>%                   # Group by Peptide_Order
  slice_min(order_by = PPI, n = 1, with_ties = FALSE) %>%  # Select the first alphanumeric PPI per group
  ungroup() %>%
  
  # Parse pLink peptide notation into Annika-compatible sequence and crosslink-position fields.
  separate(Peptide, into = c("Accession1", "Accession2"), sep = "-") %>%
  mutate(
    Sequence.A = str_extract(Accession1, "^[A-Za-z]+"),
    Position.A = as.integer(str_extract(Accession1, "[0-9]+")),
    Sequence.B = str_extract(Accession2, "^[A-Za-z]+"),
    Position.B = as.integer(str_extract(Accession2, "[0-9]+"))
    )%>%
   # Mark the linked residue with square brackets to match the Annika/XlinkX style.
   mutate(
    Sequence.A = paste0(
      str_sub(Sequence.A, 1, Position.A - 1),
      "[", 
      str_sub(Sequence.A, Position.A, Position.A),
      "]",
      str_sub(Sequence.A, Position.A + 1)
    ),
      Sequence.B = paste0(
      str_sub(Sequence.B, 1, Position.B - 1),
      "[", 
      str_sub(Sequence.B, Position.B, Position.B),
      "]",
      str_sub(Sequence.B, Position.B + 1)
    )
  ) %>%
  # Create the direction-independent RRI key.
  rowwise() %>%  # Apply operations row-wise
  mutate(
  RRA = paste(Accession.A, In.protein.A, sep = ":"),
  RRB = paste(Accession.B, In.protein.B, sep = ":")
  ) %>%
  ungroup() %>%
  rowwise() %>%
  mutate(RRI = paste(sort(c(RRA, RRB)), collapse = "-"))%>% #sort alphanumeric then combine to make RRI
  ungroup() %>% # Remove row-wise grouping
  select(-c(Accession1, Accession2, RRA, RRB)) # Remove temporary parsing columns.
```
