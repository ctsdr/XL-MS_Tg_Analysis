## 11. Merge cleavable and non-cleavable RRI tables

This section combines Annika-derived cleavable RRIs with pLink-derived non-cleavable RRIs. When an RRI is observed in both methods, the workflow keeps the best confidence score, sums CSM support, and labels the method as `both`.

```{r merge-rri-cleaved-noncleaved}
# Ensure the pLink RRI table has a non-cleavable method label before merging.
RRI_noncleaved_full <- RRI_noncleaved_full %>% mutate(MS = "noncleaved") %>%
  # Convert pLink peptide notation to the Annika-style bracketed target residue format.
   mutate(
    Sequence.A = paste0(
      str_sub(Sequence.A, 1, Position.A - 1),
      "[", 
      str_sub(Sequence.A, Position.A, Position.A),
      "]",
      str_sub(Sequence.A, Position.A + 1)
    ),
      Sequence.B = paste0(
      str_sub(Sequence.B, 1, Position.B - 1),
      "[", 
      str_sub(Sequence.B, Position.B, Position.B),
      "]",
      str_sub(Sequence.B, Position.B + 1)
    )
  )

# Merge the cleavable and non-cleavable RRI tables by the RRI key.
RRI_full <- full_join(RRI_clean, RRI_noncleaved_full, join_by(RRI))%>%
    # Convert numeric-looking character columns to numeric values for downstream calculations.
    mutate(across(
      where(is.character),
      ~ {
        # test non-NA entries
        vals <- .x[!is.na(.x)]
        if (all(str_detect(vals, "^\\d+(\\.\\d+)?$"))) {
        as.numeric(.x)
        } else {
          .x
        }
      }
    ))%>%
  mutate(
    MS = case_when( # MS indicates which method detected the PPI: cleaved, noncleaved, or both.
      !is.na(MS.x) & !is.na(MS.y) ~ "both",  # Both values exist
      !is.na(MS.x) & (is.na(MS.y)) ~ MS.x, # Only MS.x exists
      is.na(MS.x) & !is.na(MS.y) ~ MS.y,                   # Only MS.y exists
      TRUE ~ NA_character_))%>%
  # Keep the higher Confidence.Q value across the two methods.
  mutate(Confidence.Q = pmax(Confidence.Q.x, Confidence.Q.y, na.rm = TRUE)) %>%
  # Sum CSM support and unique RRI support across methods.
  mutate(Number.of.CSMs = rowSums(select(., Number.of.CSMs.x, Number.of.CSMs.y), na.rm = TRUE)) %>%
  # Keep only the columns needed for feature construction.
  select(-c(Confidence, Confidence.Q.x, Confidence.Q.y, Crosslinks.Peptide.Group.ID, 
            Peptide_Order, Number.of.CSMs.x, Number.of.CSMs.y, MS.x, MS.y, 
            Protein.Descriptions.A, Protein.Descriptions.B)) %>%
  # Coalesce duplicate columns from the join: prefer cleavable `.x` values and fill from non-cleavable `.y`.
  mutate(across(ends_with(".x"), ~ coalesce(.x, get(sub("\\.x$", ".y", cur_column()))))) %>%
  # Remove `.x` suffixes after coalescing duplicate columns.
  rename_with(
    .fn = ~ str_replace(., "\\.x$", ""),  # Function to remove '.x' at the end
    .cols = ends_with(".x")                # Select columns that end with '.x'
              ) %>%
  # Keep the compact RRI table used for structural mapping and exports.
  select(c(RRI, PPI, Accession.A, Accession.B, Confidence.Q, Number.of.CSMs, MS, Sequence.A, Position.A, Sequence.B, Position.B, In.protein.A, In.protein.B, Crosslink.Type, RRI.Score))

