# Define a function to clean specified columns with specific patterns, prefix removal, and custom string removals
clean_gene_product <- function(data, columns) {
  # Apply multiple transformations within mutate across the specified columns
  data %>% 
    mutate(across(all_of(columns), ~if_else(
      str_starts(., "transcript"),  # Check if starts with "transcript"
      str_split(., "\\|", simplify = TRUE)[, 4],  # Split and select the 4th element if condition is met
      .  # Keep the original value if condition is not met
    ))) %>%
    mutate(across(all_of(columns), ~str_remove(., "^\\s*gene_product="))) %>%  # Remove the "gene_product=" prefix
    mutate(across(all_of(columns), ~str_remove(., "dense granule protein "))) %>%  # Remove "dense granule protein " prefix
    mutate(across(all_of(columns), ~str_remove(., "ribosomal protein "))) %>%  # Remove "ribosomal protein " prefix
    mutate(across(all_of(columns), ~str_remove(., "SAG-related sequence "))) %>%  # Remove "SAG-related sequence
    mutate(across(all_of(columns), ~str_remove(., "heat shock protein ")))  # Remove "heat shock protein " prefix
}

# apply that funciton to df
