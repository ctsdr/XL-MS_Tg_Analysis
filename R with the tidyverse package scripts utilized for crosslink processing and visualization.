## 16. Merge cleavable and non-cleavable PPI tables

This is the combined PPI-level table used for machine-learning feature construction and Cytoscape interactome analysis. PPIs observed by both methods retain the higher confidence score and summed spectral/RRI support.

```{r merge-ppi-cleaved-noncleaved}
PPI_full <- full_join(PPI_cleaved_full %>% filter(Crosslink.Type == "Inter"), 
                      PPI_noncleaved_full %>% filter(Crosslink.Type == "Inter"), 
                      join_by(PPI)) %>%
    mutate(
      MS = case_when( # MS indicates which method detected the PPI: cleaved, noncleaved, or both.
      !is.na(MS.x) & !is.na(MS.y) ~ "both",  # Both values exist
      !is.na(MS.x) & (is.na(MS.y)) ~ MS.x, # Only MS.x exists
      is.na(MS.x) & !is.na(MS.y) ~ MS.y,                   # Only MS.y exists
      TRUE ~ NA_character_)
    ) %>%
    # Keep the higher Confidence.Q value across the two methods.
    mutate(Confidence.Q = pmax(Confidence.Q.x, Confidence.Q.y, na.rm = TRUE)) %>%
 # Sum CSM support and unique RRI support across methods.
    mutate(Number.of.CSMs = rowSums(select(., Number.of.CSMs.x, Number.of.CSMs.y), na.rm = TRUE)) %>%
    mutate(number_unique_RR = rowSums(select(., number_unique_RR.x, number_unique_RR.y), na.rm = TRUE)) %>%
   # Keep only the columns needed for feature construction.
    select(c(
      Confidence.Q, Accession.A.x, Accession.B.x, PPI, Accession.A.y, Accession.B.y, MS, 
      Number.of.CSMs, number_unique_RR, number_unique_intra.min.x, number_unique_intra.min.y, PPI.Score.x, PPI.Score.y)
      ) %>%
  # Coalesce duplicate columns from the join: prefer cleavable `.x` values and fill from non-cleavable `.y`.
  mutate(across(ends_with(".x"), ~ coalesce(.x, get(sub("\\.x$", ".y", cur_column()))))) %>%
  # Remove `.x` suffixes after coalescing duplicate columns.
  rename_with(
    .fn = ~ str_replace(., "\\.x$", ""),  # Function to remove '.x' at the end
    .cols = ends_with(".x")                # Select columns that end with '.x'
              ) %>%
  # Keep the compact RRI table used for structural mapping and exports.
  select(-c(Accession.A.y, Accession.B.y, PPI.Score.y, number_unique_intra.min.y))
