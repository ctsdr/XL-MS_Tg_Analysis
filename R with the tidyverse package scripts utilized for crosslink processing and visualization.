#calculate the overlap between cleaved and noncleaved RRI
```{r}
# Define FDR levels and their corresponding filter conditions
fdr_levels <- list(
  FDR05 = "Confidence.Q >= 4",
  FDR01 = "Confidence.Q == 5"
)

# Function to compute counts for a given filter condition
compute_counts <- function(df_noncleaved, df_cleaved, filter_condition) {
  
  # Filter the data based on the provided condition
  RRI_noncleaved_filtered <- df_noncleaved %>% filter(eval(parse(text = filter_condition)))
  RRI_cleaved_filtered <- df_cleaved %>% filter(eval(parse(text = filter_condition)))
  
  # Total number of observations
  total_noncleaved <- RRI_noncleaved_filtered %>% summarise(count = n()) %>% pull(count)
  total_cleaved <- RRI_cleaved_filtered %>% summarise(count = n()) %>% pull(count)
  
  # Total unique RRIs
  unique_noncleaved <- RRI_noncleaved_filtered %>% distinct(RRI) %>% summarise(count = n()) %>% pull(count)
  unique_cleaved <- RRI_cleaved_filtered %>% distinct(RRI) %>% summarise(count = n()) %>% pull(count)
  
  # Shared RRIs
  shared_rris <- RRI_noncleaved_filtered %>% inner_join(RRI_cleaved_filtered, by = "RRI") %>% distinct(RRI)
  count_shared <- shared_rris %>% summarise(count = n()) %>% pull(count)
  
  # Unique RRIs only in each data frame
  unique_only_noncleaved <- unique_noncleaved - count_shared
  unique_only_cleaved <- unique_cleaved - count_shared
  
  # Count Crosslink Types within Shared RRIs
  # Assuming "Crosslink.Type" is present in both data frames and is consistent between them
  # We'll retrieve it from the noncleaved data frame; alternatively, you can choose one
  shared_with_type <- shared_rris %>%
    inner_join(RRI_noncleaved_filtered, by = "RRI") %>%
    select(RRI, Crosslink.Type)
  
  # Count the number of Intra and Inter types
  count_intra <- shared_with_type %>%
    filter(Crosslink.Type == "Intra") %>%
    summarise(count = n()) %>%
    pull(count)
  
  count_inter <- shared_with_type %>%
    filter(Crosslink.Type == "Inter") %>%
    summarise(count = n()) %>% 
    pull(count)
  
  # Handle cases where there might be no Intra or Inter types
  count_intra <- ifelse(length(count_intra) == 0, 0, count_intra)
  count_inter <- ifelse(length(count_inter) == 0, 0, count_inter)
  
  # Return a named vector of counts, including the new metrics
  c(
    Total_Observations_RRI_noncleaved = total_noncleaved,
    Total_Observations_RRI_cleaved = total_cleaved,
    Unique_RRIs_RRI_noncleaved = unique_noncleaved,
    Unique_RRIs_RRI_cleaved = unique_cleaved,
    Shared_RRIs = count_shared,
    Shared_RRIs_Intra = count_intra,
    Shared_RRIs_Inter = count_inter,
    Unique_RRIs_only_RRI_noncleaved = unique_only_noncleaved,
    Unique_RRIs_only_RRI_cleaved = unique_only_cleaved
  )
}

# Initialize an empty list to store results for each FDR level
results_list <- list()

# Iterate over each FDR level and compute counts
for (fdr in names(fdr_levels)) {
  counts <- compute_counts(RRI_noncleaved_full, RRI_clean, fdr_levels[[fdr]])
  results_list[[fdr]] <- counts
}

# Convert the list to a data frame
summary_df <- bind_rows(results_list, .id = "FDR") %>%
  pivot_longer(
    cols = -FDR,
    names_to = "Metric",
    values_to = "Count"
  ) %>%
  pivot_wider(
    names_from = FDR,
    values_from = Count
  )

# Optional: Arrange the metrics in a specific order
