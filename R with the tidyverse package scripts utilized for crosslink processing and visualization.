## 13. Analyze structural distances for mapped crosslinks

This section imports XMAS distance outputs and compares observed inter/intra crosslink distances with all possible K/S/T/Y residue-pair distances generated from PyMOL.

```{r structural-distance-analysis}
# Import XMAS distance measurements.
intra_tsvdf <- read.table("TachyAll_XL_publication_20240916_XMAS_intra_LRibosome.tsv",
                      header = TRUE, 
                      fill = TRUE, 
                      sep = "\t", 
                      comment.char = "") %>% 
                  na.omit() %>%
                  mutate(Crosslink.Type = "intra")
# Import the small ribosomal subunit intra-link distance measurements.
intra_tsvdf2 <- read.table("TachyAll_XL_publication_20240916_XMAS_intra_SRibosome.tsv",
                      header = TRUE, 
                      fill = TRUE, 
                      sep = "\t", 
                      comment.char = "") %>% 
                  na.omit() %>%
                  mutate(Crosslink.Type = "intra")
# Combine large- and small-subunit intralink distance measurements.
intra_tsvdf <- rbind(intra_tsvdf, intra_tsvdf2)

# Import XMAS distance measurements.
inter_tsvdf <- read.table("TachyAll_XL_publication_20240916_XMAS_inter_LRibosome.tsv",
                      header = TRUE, 
                      fill = TRUE, 
                      sep = "\t", 
                      comment.char = "") %>% 
                  na.omit() %>%
                  mutate(Crosslink.Type = "inter")
                  
# Import XMAS distance measurements.
inter_tsvdf2 <- read.table("TachyAll_XL_publication_20240916_XMAS_inter_SRibosome.tsv",
                      header = TRUE, 
                      fill = TRUE, 
                      sep = "\t", 
                      comment.char = "") %>% 
                  na.omit() %>%
                  mutate(Crosslink.Type = "inter")

# Combine large- and small-subunit intralink distance measurements.
inter_tsvdf <- rbind(inter_tsvdf, inter_tsvdf2)

# Combine observed inter- and intralink distances.
distance_df <- rbind(inter_tsvdf, intra_tsvdf)%>%
  select(Distance..A., Crosslink.Type)

# Import the PyMOL-derived distance distribution for all possible K/S/T/Y interprotein residue pairs.
# Load all possible interprotein residue-pair distances.
inter_possible <- read.table(
  "XMAS_interprotein_ca_distancesKSTY.txt",
  header = TRUE,
  sep = "\t",
  fill = TRUE,
  fileEncoding = "Windows-1252",  # PyMOL output uses Windows-1252 encoding; set fileEncoding explicitly to avoid import errors.
  stringsAsFactors = FALSE
  )%>%
  mutate(Crosslink.Type = "possible")%>%
  rename(Distance..A. = Distance..Å.)%>%
  select(Distance..A., Crosslink.Type)

# Load all possible intraprotein residue-pair distances.
intra_possible <- read.table(
  "XMAS_intra_ca_distancesKSTY.txt",
  header = TRUE,
  sep = "\t",
  fill = TRUE,
  fileEncoding = "Windows-1252",  # PyMOL output uses Windows-1252 encoding; set fileEncoding explicitly to avoid import errors.
  stringsAsFactors = FALSE
  )%>%
  mutate(Crosslink.Type = "possible")%>%
  rename(Distance..A. = Distance..Å.)%>%
  select(Distance..A., Crosslink.Type)

# Add all possible residue-pair distances to the observed-distance table.
distance_df <- bind_rows(distance_df, inter_possible, intra_possible)

# Summarize observed and possible distance distributions by crosslink type.
grouped_summary <- distance_df %>%
  group_by(Crosslink.Type) %>%
  summarise(
    Observations = n(),
    Mean = mean(`Distance..A.`, na.rm = TRUE),
    Median = median(`Distance..A.`, na.rm = TRUE),
    SD = sd(`Distance..A.`, na.rm = TRUE)
  ) %>%
  ungroup() # Ungroup to prevent grouping affecting further operations

# Calculate overall distance statistics across all groups.
overall_summary <- distance_df %>%
  summarise(
    Crosslink.Type = "Overall",
    Observations = n(),
    Mean = mean(`Distance..A.`, na.rm = TRUE),
    Median = median(`Distance..A.`, na.rm = TRUE),
    SD = sd(`Distance..A.`, na.rm = TRUE)
  )

# Combine overall and grouped summaries for inspection/export.
