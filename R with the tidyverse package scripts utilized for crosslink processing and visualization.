    In.protein.A = as.numeric(str_split(In.protein.A, ";", simplify = TRUE)[,1]),
    In.protein.B = as.numeric(str_split(In.protein.B, ";", simplify = TRUE)[,1]),

    # Calculate Peptide.A.Start and Peptide.B.Start
    Peptide.A.Start = In.protein.A - Position.A + 1,
    Peptide.B.Start = In.protein.B - Position.B + 1,
    
    # Extract substring after ']' in Sequence.A and Sequence.B
    # and calculate Peptide.A.End and Peptide.B.End
    Peptide.A.End = In.protein.A + str_length(str_remove(Sequence.A, "^.*\\]")),
    Peptide.B.End = In.protein.B + str_length(str_remove(Sequence.B, "^.*\\]")),
    
    # Determine if there is any overlap between the peptide ranges
    Dimer = (Peptide.A.Start <= Peptide.B.End) & (Peptide.B.Start <= Peptide.A.End)
  ) %>%
    filter(Dimer == TRUE)

